<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Criar Conta — AutoMec</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar">
  <a href="/" class="nav-logo">AUTO<span class="dot">·</span>MEC</a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/login">Entrar</a></li>
  </ul>
</nav>

<div class="auth-page">
  <div class="auth-box" style="max-width:460px">

    <span class="label">Novo Cliente</span>
    <h1>CRIAR CONTA</h1>
    <p class="sub">Cadastre-se para agendar serviços online com facilidade.</p>

    <% if (locals.erro && erro) { %>
      <div class="alert alert-error">⚠ <%= erro %></div>
    <% } %>

    <form method="POST" action="/cadastro">

      <div class="form-group">
        <label for="nome">Nome Completo</label>
        <input type="text" id="nome" name="nome"
               placeholder="João Silva" required autocomplete="name">
      </div>

      <div class="form-group">
        <label for="email">E-mail</label>
        <input type="email" id="email" name="email"
               placeholder="seuemail@exemplo.com" required autocomplete="email">
      </div>

      <div class="form-group">
        <label for="senha">Senha</label>
        <input type="password" id="senha" name="senha"
               placeholder="Mínimo 6 caracteres" required autocomplete="new-password">
      </div>

      <button type="submit" class="btn btn-primary"
              style="width:100%;justify-content:center;margin-top:.5rem">
        Criar Conta →
      </button>
    </form>

    <div class="form-foot">
      Já tem conta? <a href="/login">Fazer login</a>
    </div>

  </div>
</div>

</body>
</html>
