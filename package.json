{
  "name": "mechanic-site",
  "version": "2.0.0",
  "description": "Sistema de agendamento para oficina mecânica",
  "private": true,
  "scripts": {
    "dev:backend": "cd back-end && npm run dev",
    "dev:frontend": "cd front-end && npm run dev",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd front-end && npm run build",
    "start": "cd back-end && npm start",
    "postinstall": "echo 'Dependencies installed'"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.2",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
